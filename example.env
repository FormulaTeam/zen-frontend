# API base URL (used by axios)
REACT_APP_API_URL=http://localhost:3000/api

# Keycloak authorization endpoint
# redirect_uri is appended dynamically by Login.tsx
REACT_APP_KEYCLOAK_URL=http://localhost:8080/realms/formula/protocol/openid-connect/auth?client_id=engine&response_type=code&scope=openid+profile
